@using PersonalFinanceApp.Data.Models
@using PersonalFinanceApp.Data.Services
@inject LoginService LoginService


<EditForm Model="model" OnValidSubmit="HandleSubmit">
    <p>Welcome '@Username' to the app, please fill out the information below to create your new account.</p>

    <InputText  type="password" @bind-Value="model.Password" placeholder="Enter a Password" />
    <InputText @bind-Value="model.FirstName" placeholder="Enter your First Name" />
    <InputText @bind-Value="model.LastName" placeholder="Enter your Last Name" />
    <InputText @bind-Value="model.Email" placeholder="Enter your Email" />

    <button type="submit" disabled=@isFormInvalid>Create Account</button>

</EditForm>


@code {
    [Parameter] public required string Username { get; set; }
    [Parameter] public EventCallback<SignupModel> OnSignupSubmit { get; set; }
    public SignupModel model = new();
    private bool isFormInvalid => 
        string.IsNullOrEmpty(model.Password) || 
        string.IsNullOrEmpty(model.FirstName) || 
        string.IsNullOrEmpty(model.LastName) || 
        string.IsNullOrEmpty(model.Email);


    private async Task HandleSubmit() {
        model.Username = Username;
        await OnSignupSubmit.InvokeAsync(model);
    }
}

