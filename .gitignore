# Broad rules to catch all build outputs
**/[Bb]in/
**/[Oo]bj/
**/[Dd]ebug/
**/[Rr]elease/
**/bin\\Debug/
**/"bin\Debug"/
**/bin?Debug/



# Database files (don't commit your local testing data!)
*.db
*.db-shm
*.db-wal



# MAUI platform build outputs
**/Platforms/Android/bin/
**/Platforms/Android/obj/
**/Platforms/iOS/bin/
**/Platforms/iOS/obj/
**/Platforms/MacCatalyst/bin/
**/Platforms/MacCatalyst/obj/
**/Platforms/Windows/bin/
**/Platforms/Windows/obj/

# Device-specific / generated files
*.apk
*.aab
*.ipa
*.app
*.xcarchive/

# Visual Studio / VS Code
.vs/
.vscode/
*.code-workspace

# User-specific settings
*.user
*.suo

# Logs
*.log

# Node (if using frontend tooling)
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log

# Environment variables
*.env

# NuGet
*.nupkg
packages/

# JetBrains Rider
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# Backup / temp files
*.tmp
*.bak
*.swp

# Dotnet tools
.dotnet-tools/

# MAUI generated resources
Resources/Raw/*.zip
